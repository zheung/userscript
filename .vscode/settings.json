{
	"explorer.fileNesting.patterns": {
		"package.json": "pnpm-lock.yaml, pnpm-workspace.yaml, tsconfig.json, eslint.config.js, .gitignore, CHANGELOG.md, README.md, README.*.md, LICENSE",
		"vite-script.js": "vite-script.watch.js,postcss.config.js, uno.config.js",
		"index.js": "index.html, index.env.js"
	},
	"editor.tabSize": 4,
	"editor.insertSpaces": false,
	"editor.detectIndentation": true,
	"files.eol": "\n",
	"files.insertFinalNewline": true,
	"files.trimFinalNewlines": true,
	"files.trimTrailingWhitespace": true,
	"js/ts.preferences.importModuleSpecifierEnding": "js",
	"js/ts.format.insertSpaceAfterFunctionKeywordForAnonymousFunctions": false,
	"js/ts.format.insertSpaceAfterKeywordsInControlFlowStatements": false,
	"js/ts.format.semicolons": "insert",
	"js/ts.preferences.quoteStyle": "single",
	"js/ts.suggestionActions.enabled": false,
	"js/ts.updateImportsOnFileMove.enabled": "always",
}
