{
	"compilerOptions": {
		"module": "esnext",
		"moduleResolution": "bundler",
		"target": "esnext",
		"composite": true,
		"allowJs": true,
		"declaration": true,
		"emitDeclarationOnly": true,
		"declarationDir": "./types",
		"types": [
			"node",
			"tampermonkey",
			"wicg-file-system-access",
		],
	},
	"include": [
		"**/*.js",
		"**/*.vue"
	],
	"exclude": [
		"eslint.config.js",
		"node_modules",
		"test",
		"dist",
		"dev-vue"
	]
}
